{
  "schemaVersion": "1.0.0",
  "kind": "fx-effect",
  "name": "Torch Flame",
  "description": "Animated flame for graveyard lanterns + torches. Attached at level load to entities whose Name matches the configured prefix.",
  "shader": "cow_survivor::torch_flame",
  "geometry": "cube",
  "attachTo": { "namePrefix": "Decor_LanternGlow_" },
  "params": {
    "baseColor": [0.55, 1.0, 0.45],
    "metallic": 0,
    "roughness": 1.8
  },
  "paramSemantics": {
    "metallic": "time-elapsed-seconds",
    "roughness": "intensity-multiplier"
  }
}
